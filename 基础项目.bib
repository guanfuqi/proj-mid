@article{gaoIMOFCIdentitylevelMetric2025,
  title = {{{IMOFC}}: Identity-Level Metric Optimized Feature Compression for Identification Tasks},
  shorttitle = {Imofc},
  author = {Gao, Changsheng and Jiang, Yiheng and Wu, Siqi and Ma, Yifan and Li, Li and Liu, Dong},
  year = 2025,
