@article{kongMultiscaleSpatialspectralAttention2022a,
  title = {Multi-Scale Spatial-Spectral Attention Network for Multispectral Image Compression Based on Variational Autoencoder},
  author = {Kong, Fanqiang and Cao, Tongbo and Li, Yunsong and Li, Dan and Hu, Kedi},
  year = 2022,
